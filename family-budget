<!-- SHEET MODAL -->
<div class="overlay" id="overlay" onclick="if(event.target===this)closeSheet()">
  <div class="sheet">
    <div class="sh-handle"></div>
    <div class="sh-title">내 이름 설정</div>
    <div class="sh-desc">내역에 표시되는 이름이에요.<br>가족마다 다른 이름으로 구분해요.</div>
    <div class="fg">
      <label class="fl" for="nn">이름</label>
      <input class="fi" id="nn" type="text" maxlength="8" placeholder="예: 엄마, 아빠, 지수" onkeydown="if(event.key==='Enter')saveNick()">
    </div>
    <div class="sh-btns">
      <button class="sh-cancel" id="sh-cancel" onclick="closeSheet()">취소</button>
      <button class="sh-ok" onclick="saveNick()">확인</button>
    </div>
  </div>
