/* ═══════════════ RENDER ANALYSIS ═══════════════ */
function renderAn(){
  const data=filterByPeriod(txns);
  const inc=data.filter(t=>t.type==='i').reduce((s,t)=>s+t.amount,0);
  const exp=data.filter(t=>t.type==='e').reduce((s,t)=>s+t.amount,0);
  const bal=inc-exp;

  document.getElementById('an-inc').textContent=fmt(inc);
  document.getElementById('an-exp').textContent=fmt(exp);
  const bel=document.getElementById('an-bal');
  bel.textContent=(bal<0?'−':'')+fmt(bal);
  bel.style.color=bal>=0?'var(--green)':'var(--red)';

  /* ── 멤버별 ── */
  const members=[...new Set(data.map(t=>t.who))];
  const membersAll=[...new Set(txns.map(t=>t.who))]; // for stable color
  document.getElementById('an-members').innerHTML=members.length
    ?members.map(m=>{
        const midx=membersAll.indexOf(m);
        const col=memberColor(m,midx);
        const colL=memberColorL(m,midx);
        const mInc=data.filter(t=>t.who===m&&t.type==='i').reduce((s,t)=>s+t.amount,0);
        const mExp=data.filter(t=>t.who===m&&t.type==='e').reduce((s,t)=>s+t.amount,0);
        const net=mInc-mExp;
        const cnt=data.filter(t=>t.who===m).length;
        // top cats for this member
        const catMap={};
        data.filter(t=>t.who===m&&t.type==='e').forEach(t=>{catMap[t.cat]=(catMap[t.cat]||0)+t.amount});
        const topCats=Object.entries(catMap).sort((a,b)=>b[1]-a[1]).slice(0,4);
        const maxCat=topCats[0]?topCats[0][1]:1;
        const topCatsHTML=topCats.length?`
          <div class="mem-top-cats">
            <div class="mem-tc-title">주요 지출 카테고리</div>
            ${topCats.map(([c,v])=>`<div class="mem-cat-row">
              <div class="mcr-lbl">${ICO[c]||''} ${c}</div>
              <div class="mcr-track"><div class="mcr-fill" style="width:${Math.round(v/maxCat*100)}%;background:${col}"></div></div>
              <div class="mcr-val">${fmt(v)}</div>
            </div>`).join('')}
          </div>`:'';
        // 결제수단 통계
        const payData=data.filter(t=>t.who===m&&t.type==='e'&&t.payment);
        const cardAmt=payData.filter(t=>t.payment==='card').reduce((s,t)=>s+t.amount,0);
        const cashAmt=payData.filter(t=>t.payment==='cash').reduce((s,t)=>s+t.amount,0);
        // 카드별 분포
        const cardMap={};
        payData.filter(t=>t.payment==='card'&&t.card).forEach(t=>{cardMap[t.card]=(cardMap[t.card]||0)+t.amount;});
        const topCards=Object.entries(cardMap).sort((a,b)=>b[1]-a[1]).slice(0,3);
        // 식비 세부
        const foodData=data.filter(t=>t.who===m&&t.type==='e'&&t.cat==='식비'&&t.foodSub);
        const foodMap={mart:0,delivery:0,'eating-out':0};
        foodData.forEach(t=>{foodMap[t.foodSub]=(foodMap[t.foodSub]||0)+t.amount;});
        const foodTotal=Object.values(foodMap).reduce((a,b)=>a+b,0);
        const foodSubHTML=foodTotal>0?`
          <div class="mem-top-cats" style="margin-top:10px;padding-top:10px;border-top:1px solid var(--line2)">
            <div class="mem-tc-title">🍚 식비 세부</div>
            <div style="display:flex;gap:6px;flex-wrap:wrap">
              ${foodMap.mart>0?`<span class="mem-pay-chip">🛒 장보기 ${fmt(foodMap.mart)}</span>`:''}
              ${foodMap.delivery>0?`<span class="mem-pay-chip">🛵 배달 ${fmt(foodMap.delivery)}</span>`:''}
              ${foodMap['eating-out']>0?`<span class="mem-pay-chip">🍽️ 외식 ${fmt(foodMap['eating-out'])}</span>`:''}
            </div>
          </div>`:'';
        const payHTML=(cardAmt||cashAmt)?`
          <div class="mem-top-cats" style="margin-top:10px;padding-top:10px;border-top:1px solid var(--line2)">
            <div class="mem-tc-title">💳 결제수단</div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:${topCards.length?'8px':'0'}">
              ${cardAmt>0?`<span class="mem-pay-chip" style="background:var(--blue-l);color:var(--blue)">💳 카드 ${fmt(cardAmt)}</span>`:''}
              ${cashAmt>0?`<span class="mem-pay-chip">💵 현금 ${fmt(cashAmt)}</span>`:''}
            </div>
            ${topCards.length?`<div style="font-size:10px;color:var(--t3);margin-bottom:4px">주요 카드</div>
            <div style="display:flex;gap:6px;flex-wrap:wrap">${topCards.map(([c,v])=>`<span class="mem-pay-chip" style="background:var(--blue-l);color:var(--blue)">${c} ${fmt(v)}</span>`).join('')}</div>`:''}
          </div>`:'';
        // 지출 비율 (전체 대비)
        const totalAllExp=data.filter(t=>t.type==='e').reduce((s,t)=>s+t.amount,0);
        const expRatio=totalAllExp>0?Math.round(mExp/totalAllExp*100):0;
        return`<div class="mem-item">
          <div class="mem-top">
            <div class="mem-av" style="background:${colL};color:${col}">${m[0]}</div>
            <div class="mem-info">
              <div class="mem-nm">${esc(m)}</div>
              <div class="mem-cnt">${cnt}건 기록 · 전체 지출의 ${expRatio}%</div>
            </div>
            <div class="mem-net" style="color:${net>=0?'var(--green)':'var(--red)'}">${net>=0?'+':'−'}${fmt(net)}</div>
          </div>
          <div class="mem-detail-grid">
            <div class="mem-stat-box">
              <div class="mem-stat-lbl">수입</div>
              <div class="mem-stat-val" style="color:var(--green)">+${fmt(mInc)}</div>
            </div>
            <div class="mem-stat-box">
              <div class="mem-stat-lbl">지출</div>
              <div class="mem-stat-val" style="color:var(--red)">−${fmt(mExp)}</div>
            </div>
            <div class="mem-stat-box">
              <div class="mem-stat-lbl">건당 평균</div>
              <div class="mem-stat-val">${cnt>0?fmt(Math.round(mExp/Math.max(data.filter(t=>t.who===m&&t.type==='e').length,1))):'−'}</div>
            </div>
            <div class="mem-stat-box">
              <div class="mem-stat-lbl">잔액</div>
              <div class="mem-stat-val" style="color:${net>=0?'var(--green)':'var(--red)'}">${net>=0?'+':'−'}${fmt(net)}</div>
            </div>
          </div>
          ${topCatsHTML}
          ${payHTML}
          ${foodSubHTML}
        </div>`;
      }).join('')
    :`<div class="empty-t" style="color:var(--t3);font-size:13px;text-align:center;padding:16px">내역이 없어요</div>`;

  /* ── 카테고리 도넛 + 목록 ── */
  const catMap={};
  data.filter(t=>t.type==='e').forEach(t=>{catMap[t.cat]=(catMap[t.cat]||0)+t.amount});
  const catArr=Object.entries(catMap).sort((a,b)=>b[1]-a[1]);
  const totalExp=catArr.reduce((s,[,v])=>s+v,0);
  document.getElementById('an-cat-total').textContent=totalExp?`총 ${fmt(totalExp)}`:'';

  // donut SVG
  if(catArr.length){
    const top6=catArr.slice(0,6);
    const otherSum=catArr.slice(6).reduce((s,[,v])=>s+v,0);
    const segments=otherSum>0?[...top6,['기타합산',otherSum]]:top6;
    const total=segments.reduce((s,[,v])=>s+v,0);
    const R=52,cx=60,cy=60,strokeW=18;
    let offset=0;
    const circ=2*Math.PI*R;
    const paths=segments.map(([,v],i)=>{
      const pct=v/total;
      const dash=circ*pct-1;
      const path=`<circle cx="${cx}" cy="${cy}" r="${R}" fill="none" stroke="${CAT_COLORS[i%CAT_COLORS.length]}" stroke-width="${strokeW}" stroke-dasharray="${dash} ${circ-dash}" stroke-dashoffset="${-offset*circ+circ/4}" stroke-linecap="butt"/>`;
      offset+=pct; return path;
    }).join('');
    const legend=segments.slice(0,5).map(([c,v],i)=>
      `<div class="dl-item"><div class="dl-dot" style="background:${CAT_COLORS[i%CAT_COLORS.length]}"></div><div class="dl-nm">${c==='기타합산'?'기타':c}</div><div class="dl-pct">${Math.round(v/total*100)}%</div></div>`
    ).join('');
    document.getElementById('an-donut').innerHTML=`<div class="donut-wrap">
      <svg class="donut-svg" width="120" height="120" viewBox="0 0 120 120">${paths}</svg>
      <div class="donut-legend">${legend}</div>
    </div>`;
  } else {
    document.getElementById('an-donut').innerHTML='';
  }

  // cat list
  const maxV=catArr[0]?catArr[0][1]:1;
  document.getElementById('an-cats').innerHTML=catArr.length
    ?catArr.map(([c,v],i)=>`<div class="cat-item">
        <div class="cat-rank">${i+1}</div>
        <div class="cat-ic" style="background:${CAT_COLORS[i%CAT_COLORS.length]}18">${ICO[c]||'📌'}</div>
        <div class="cat-info">
          <div class="cat-nm">${c}</div>
          <div class="cat-track"><div class="cat-fill" style="width:${Math.round(v/maxV*100)}%;background:${CAT_COLORS[i%CAT_COLORS.length]}"></div></div>
        </div>
        <div class="cat-rt">
          <div class="cat-val">${fmt(v)}</div>
          <div class="cat-pct">${Math.round(v/totalExp*100)}%</div>
        </div>
      </div>`).join('')
    :`<div style="color:var(--t3);font-size:13px;text-align:center;padding:16px">지출 내역이 없어요</div>`;
}

