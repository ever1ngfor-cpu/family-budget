/* ═══════════════ AI REPORT ═══════════════ */
const AI_KEY = 'fb_ai_report_v1';

function checkMonthEnd(){
  const d=new Date();
  const lastDay=new Date(d.getFullYear(),d.getMonth()+1,0).getDate();
  const isNearEnd=(lastDay-d.getDate())<=2; // 마지막 3일
  const notice=document.getElementById('ai-notice');
  if(notice) notice.classList.toggle('show',isNearEnd);
  // 서브 텍스트 업데이트
  const sub=document.getElementById('ai-banner-sub');
  if(sub){
    const y=d.getFullYear(),m=d.getMonth()+1;
    sub.textContent=`${y}년 ${m}월 · 가계부 AI 분석`;
  }
  // 저장된 리포트 있으면 표시
  try{
    const saved=JSON.parse(localStorage.getItem(AI_KEY)||'null');
    if(saved){
      const now=new Date();
      const sDate=new Date(saved.ts);
      // 같은 달 리포트면 표시
      if(sDate.getMonth()===now.getMonth()&&sDate.getFullYear()===now.getFullYear()){
        showAIResult(saved.text,true);
        return;
      }
    }
  }catch{}
}

function buildPrompt(){
  const now=new Date();
  const y=now.getFullYear(),m=now.getMonth();
  const thisMonthStart=`${y}-${String(m+1).padStart(2,'0')}-01`;
  const lastMonthStart=`${y}-${String(m).padStart(2,'0')}-01`;
  const lastMonthEnd=thisMonthStart;

  const thisMo=txns.filter(t=>t.date>=thisMonthStart);
  const lastMo=txns.filter(t=>t.date>=lastMonthStart&&t.date<lastMonthEnd);

  function summarize(list){
    const inc=list.filter(t=>t.type==='i').reduce((s,t)=>s+t.amount,0);
    const exp=list.filter(t=>t.type==='e').reduce((s,t)=>s+t.amount,0);
    const catMap={};
    list.filter(t=>t.type==='e').forEach(t=>{catMap[t.cat]=(catMap[t.cat]||0)+t.amount;});
    const cats=Object.entries(catMap).sort((a,b)=>b[1]-a[1]);
    const members=[...new Set(list.map(t=>t.who))];
    const memStats=members.map(mem=>{
      const mInc=list.filter(t=>t.who===mem&&t.type==='i').reduce((s,t)=>s+t.amount,0);
      const mExp=list.filter(t=>t.who===mem&&t.type==='e').reduce((s,t)=>s+t.amount,0);
      return `${mem}: 수입 ${mInc.toLocaleString()}원, 지출 ${mExp.toLocaleString()}원`;
    });
    return {inc,exp,cats,memStats};
  }

  const cur=summarize(thisMo);
  const prev=summarize(lastMo);

  return `당신은 가족 가계부 AI 분석가입니다. 아래 데이터를 바탕으로 이번 달 가계 분석 리포트를 작성해 주세요.

[이번 달 (${y}년 ${m+1}월)]
- 총 수입: ${cur.inc.toLocaleString()}원
- 총 지출: ${cur.exp.toLocaleString()}원
- 잔액: ${(cur.inc-cur.exp).toLocaleString()}원
- 카테고리별 지출: ${cur.cats.map(([c,v])=>`${c} ${v.toLocaleString()}원`).join(', ')||'없음'}
- 멤버별: ${cur.memStats.join(' / ')||'없음'}

[지난 달 (${y}년 ${m}월)]
- 총 수입: ${prev.inc.toLocaleString()}원
- 총 지출: ${prev.exp.toLocaleString()}원
- 카테고리별 지출: ${prev.cats.map(([c,v])=>`${c} ${v.toLocaleString()}원`).join(', ')||'없음'}

다음 형식으로 친근하고 실용적인 한국어로 작성해 주세요 (총 200자 이내, 이모지 포함):
1. 이번 달 총평 한 줄 (수입/지출 비교)
2. 지난 달 대비 가장 많이 늘어난 지출 카테고리와 금액
3. 가장 줄여야 할 항목 1~2개와 구체적인 절약 팁
4. 가족 중 지출이 가장 많은 멤버에게 한마디`;
}

async function runAI(){
  if(!txns.length){toast('내역이 없어요');return;}
  const btn=document.getElementById('ai-btn');
  const body=document.getElementById('ai-body');
  btn.disabled=true;
  btn.textContent='분석 중...';
  body.className='ai-body loading';
  body.textContent='AI가 가계부를 분석하고 있어요...';

  try{
    const resp=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        messages:[{role:'user',content:buildPrompt()}]
      })
    });
    const data=await resp.json();
    const text=data.content?.map(c=>c.text||'').join('')||'분석 결과를 가져오지 못했어요.';
    // 저장
    localStorage.setItem(AI_KEY,JSON.stringify({text,ts:Date.now()}));
    showAIResult(text,false);
  }catch(e){
    body.className='ai-body';
    body.textContent='분석 중 오류가 발생했어요. 잠시 후 다시 시도해 주세요.';
    btn.disabled=false;
    btn.textContent='✦ 다시 시도';
  }
}

function showAIResult(text,cached){
  const body=document.getElementById('ai-body');
  const btn=document.getElementById('ai-btn');
  body.className='ai-body';
  body.textContent=text;
  btn.disabled=false;
  btn.innerHTML=cached?'✦ 다시 분석하기':'✦ 분석 완료 — 다시 분석하기';
}


