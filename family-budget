  </div><!-- /scroller -->

  <!-- BOTTOM NAV -->
  <nav class="bnav">
    <button class="nb on" onclick="go('home',this,'홈')" aria-label="홈">
      <span class="nb-ic">⌂</span><span class="nb-lb">홈</span>
    </button>
    <button class="nb" onclick="go('add',this,'추가')" aria-label="추가">
      <span class="nb-ic">＋</span><span class="nb-lb">추가</span>
    </button>
    <button class="nb" onclick="go('hist',this,'내역')" aria-label="내역">
      <span class="nb-ic">≡</span><span class="nb-lb">내역</span>
    </button>
    <button class="nb" onclick="go('an',this,'분석')" aria-label="분석">
