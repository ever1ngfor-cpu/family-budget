    <!-- ③ 내역 -->
    <div class="page" id="page-hist">
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input class="search-input" id="search-input" type="text" placeholder="내용, 작성자, 카테고리 검색..." oninput="onSearch()" autocomplete="off">
