      </div>
      <div class="fr">
        <div class="fg">
          <label class="fl" for="f-date">날짜</label>
          <input class="fi" id="f-date" type="date">
        </div>
        <div class="fg">
          <label class="fl" for="f-who">작성자</label>
          <input class="fi" id="f-who" type="text" placeholder="이름" autocomplete="off">
        </div>
      </div>
      <!-- 식비 세부 -->
      <div class="food-sub-wrap" id="food-sub-wrap">
        <div class="fg" style="margin-bottom:0">
          <label class="fl">식비 종류</label>
          <div class="sub-btns">
            <button class="sub-btn on" id="fsub-mart"  onclick="setFoodSub('mart',this)">🛒 장보기</button>
            <button class="sub-btn"   id="fsub-deliv" onclick="setFoodSub('delivery',this)">🛵 배달음식</button>
            <button class="sub-btn"   id="fsub-eat"   onclick="setFoodSub('eating-out',this)">🍽️ 외식</button>
          </div>
        </div>
      </div>

      <!-- 결제수단 (지출만) -->
      <div class="exp-only-wrap" id="exp-only-wrap">
        <div class="fg">
          <label class="fl">결제수단</label>
          <div class="pay-btns">
            <button class="pay-btn on" id="pay-card" onclick="setPayment('card',this)">💳 카드</button>
            <button class="pay-btn"   id="pay-cash" onclick="setPayment('cash',this)">💵 현금</button>
          </div>
          <div class="card-select-wrap on" id="card-select-wrap">
            <select class="fi" id="f-card" style="margin-top:11px">
              <option value="">카드 선택 (선택사항)</option>
              <option>삼성카드</option>
              <option>신한카드</option>
              <option>국민카드</option>
              <option>현대카드</option>
              <option>롯데카드</option>
              <option>우리카드</option>
              <option>하나카드</option>
              <option>NH농협카드</option>
              <option>카카오페이</option>
              <option>네이버페이</option>
              <option>토스페이</option>
              <option>기타 카드</option>
