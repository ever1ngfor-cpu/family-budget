<!DOCTYPE html>
<html lang="ko" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<title>가족가계부</title>
<link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
button,input,select{font-family:inherit;font-size:inherit}
input[type=number]::-webkit-inner-spin-button{-webkit-appearance:none}

:root{
  --font:'Pretendard',system-ui,sans-serif;
  --ease-out:cubic-bezier(.22,.68,0,1.2);
  --ease-std:cubic-bezier(.4,0,.2,1);
  --dur:180ms;
  --r-sm:12px; --r-md:16px; --r-lg:22px; --r-xl:28px;
}

/* ── LIGHT (default) ── */
[data-theme="light"]{
  --bg:#f7f6f2;
  --bg2:#ffffff;
  --bg3:#eeece7;
  --bg4:#e4e1d9;
  --line:#0000000a;
  --line2:#00000014;
  --line3:#0000001f;
  --t1:#18191f;
  --t2:#6a7080;
  --t3:#b4b8c4;
  --accent:#2d8a00;
  --accent-l:#f0fae8;
  --accent-b:#c5e8a0;
  --green:#0a8a4e;
  --green-l:#e8f8f0;
  --red:#c8392b;
  --red-l:#fdf0ee;
  --blue:#1e6bb8;
  --blue-l:#eef4fc;
  --amber:#b87000;
  --amber-l:#fdf5e6;
  --purple:#7c3aed;
  --purple-l:#f3effe;
  --surf-modal:#ffffff;
  --thumb:#d4d0c8;
  --shadow:0 1px 4px rgba(0,0,0,.07),0 4px 16px rgba(0,0,0,.06);
  --shadow-sm:0 1px 3px rgba(0,0,0,.06);
}

/* ── DARK ── */
[data-theme="dark"]{
  --bg:#101318;
  --bg2:#181c24;
  --bg3:#1f242f;
  --bg4:#252b38;
  --line:#ffffff0e;
  --line2:#ffffff18;
  --line3:#ffffff26;
  --t1:#f2f0eb;
  --t2:#9197a8;
  --t3:#555c6e;
  --accent:#a0e830;
  --accent-l:#a0e83014;
  --accent-b:#a0e83040;
  --green:#46d98a;
  --green-l:#46d98a14;
  --red:#ff5f5f;
  --red-l:#ff5f5f14;
  --blue:#5b9cf6;
  --blue-l:#5b9cf614;
  --amber:#f5b942;
  --amber-l:#f5b94214;
  --purple:#a78bfa;
  --purple-l:#a78bfa14;
  --surf-modal:#181c24;
  --thumb:#2a3040;
  --shadow:0 2px 8px rgba(0,0,0,.3);
  --shadow-sm:0 1px 4px rgba(0,0,0,.2);
}

html,body{height:100%;background:var(--bg);color:var(--t1);font-family:var(--font);-webkit-font-smoothing:antialiased}

.shell{
  display:flex;flex-direction:column;
  width:100%;max-width:430px;height:100dvh;min-height:100vh;
  margin:0 auto;background:var(--bg);overflow:hidden;
}
@media(min-width:860px){
  body{display:flex;justify-content:center;align-items:stretch;background:var(--bg3)}
  .shell{border-left:1px solid var(--line2);border-right:1px solid var(--line2);box-shadow:var(--shadow)}
}

/* ── TOPBAR ── */
.topbar{
  flex-shrink:0;
  padding:calc(env(safe-area-inset-top,0px) + 13px) 18px 13px;
  background:var(--bg2);border-bottom:1px solid var(--line2);
  display:flex;align-items:center;justify-content:space-between;gap:10px;
  position:relative;z-index:20;
}
.tb-brand{font-size:16px;font-weight:800;letter-spacing:-.5px;color:var(--accent)}
.tb-title{
  font-size:13px;font-weight:600;color:var(--t2);
  position:absolute;left:50%;transform:translateX(-50%);white-space:nowrap;
}
.tb-right{display:flex;align-items:center;gap:7px}

.theme-pill{
  display:flex;align-items:center;gap:5px;
  background:var(--bg3);border:none;border-radius:20px;
  padding:5px 10px;cursor:pointer;transition:background var(--dur);
  font-size:13px;color:var(--t2);
}
.theme-pill:hover{background:var(--bg4)}

.av-btn{
  width:34px;height:34px;border-radius:50%;border:2px solid var(--accent-b);
  background:var(--accent-l);color:var(--accent);
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:13px;cursor:pointer;flex-shrink:0;
  transition:all var(--dur);
}
.av-btn:hover{border-color:var(--accent)}

/* ── SCROLLER ── */
.scroller{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
.scroller::-webkit-scrollbar{display:none}

/* ── PAGES ── */
.page{display:none;padding:18px 16px 32px;animation:pgIn var(--dur) var(--ease-std) both}
.page.active{display:block}
@keyframes pgIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ── BOTTOM NAV ── */
.bnav{
  flex-shrink:0;display:flex;
  border-top:1px solid var(--line2);background:var(--bg2);
  padding-bottom:env(safe-area-inset-bottom,0px);
}
.nb{
  flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;
  padding:9px 4px 7px;background:transparent;border:none;cursor:pointer;
  color:var(--t3);transition:color var(--dur);position:relative;
}
.nb.on{color:var(--accent)}
.nb.on::before{
  content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);
  width:28px;height:3px;background:var(--accent);border-radius:0 0 3px 3px;
}
.nb-ic{font-size:20px;line-height:1}
.nb-lb{font-size:10px;font-weight:600;letter-spacing:.2px}

/* ══════════════════════
   DASHBOARD
══════════════════════ */
.hero{
  background:var(--bg2);border:1px solid var(--line2);
  border-radius:var(--r-lg);padding:22px 22px 20px;margin-bottom:12px;
  position:relative;overflow:hidden;box-shadow:var(--shadow-sm);
}
.hero::after{
  content:'';position:absolute;right:-30px;bottom:-30px;
  width:140px;height:140px;border-radius:50%;
  background:var(--accent);opacity:.05;pointer-events:none;
}
.hero-label{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--t3);margin-bottom:6px}
.hero-val{font-size:32px;font-weight:800;letter-spacing:-.8px;line-height:1;margin-bottom:4px}
.hero-val.pos{color:var(--accent)}
.hero-val.neg{color:var(--red)}
.hero-sub{font-size:12px;color:var(--t3)}

.mc-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px}
.mc{
  background:var(--bg2);border:1px solid var(--line2);
  border-radius:var(--r-md);padding:15px 16px;box-shadow:var(--shadow-sm);
}
.mc-top{display:flex;align-items:center;gap:7px;margin-bottom:5px}
.mc-dot{width:7px;height:7px;border-radius:50%}
.mc-lbl{font-size:11px;font-weight:600;color:var(--t2)}
.mc-val{font-size:19px;font-weight:800;letter-spacing:-.4px}
.mc-val.gr{color:var(--green)}
.mc-val.rd{color:var(--red)}

.sr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.st{font-size:14px;font-weight:700;color:var(--t1)}
.sm{font-size:12px;color:var(--t2);background:none;border:none;cursor:pointer}
.sm:hover{color:var(--t1)}

/* ── TX LIST ── */
.txl{display:flex;flex-direction:column;gap:7px}
.txc{
  background:var(--bg2);border:1px solid var(--line2);
  border-radius:var(--r-md);display:flex;align-items:center;gap:11px;
  padding:12px 13px;animation:ri .18s var(--ease-std) both;
  box-shadow:var(--shadow-sm);transition:border-color var(--dur);
}
.txc:hover{border-color:var(--line3)}
@keyframes ri{from{opacity:0;transform:translateY(-3px)}to{opacity:1;transform:translateY(0)}}
.tx-ic{width:38px;height:38px;border-radius:11px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:17px}
.tx-bd{flex:1;min-width:0}
.tx-nm{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:3px}
.tx-tg{display:flex;align-items:center;gap:4px;flex-wrap:wrap}
.tg{font-size:10px;font-weight:600;padding:2px 7px;border-radius:5px;background:var(--bg3);color:var(--t2)}
.tg-who{font-weight:700}
.tx-rt{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0}
.tx-am{font-size:14px;font-weight:800;letter-spacing:-.2px}
.tx-am.e{color:var(--red)}
.tx-am.i{color:var(--green)}
.tx-dt{font-size:10px;color:var(--t3)}
.del{background:transparent;border:none;cursor:pointer;font-size:16px;color:var(--t3);padding:1px 3px;border-radius:4px;line-height:1;transition:all var(--dur)}
.del:hover{color:var(--red);background:var(--red-l)}

.empty{text-align:center;padding:48px 20px;color:var(--t3)}
.empty-e{font-size:40px;margin-bottom:10px}
.empty-t{font-size:13px}

/* ══════════════════════
   ADD FORM
══════════════════════ */
.tseg-wrap{display:flex;background:var(--bg3);border-radius:var(--r-sm);padding:4px;gap:3px;margin-bottom:20px}
.ts{flex:1;padding:10px;border-radius:9px;border:none;background:transparent;font-size:14px;font-weight:700;color:var(--t2);cursor:pointer;transition:all var(--dur) var(--ease-std)}
.ts.ae{background:var(--red-l);color:var(--red);box-shadow:0 0 0 1px var(--red)}
.ts.ai{background:var(--green-l);color:var(--green);box-shadow:0 0 0 1px var(--green)}

.fg{margin-bottom:13px}
.fl{font-size:11px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--t2);display:block;margin-bottom:5px}
.fl span{font-weight:400;text-transform:none;letter-spacing:0;color:var(--t3)}
.fi{
  width:100%;background:var(--bg2);border:1.5px solid var(--line3);
  border-radius:var(--r-sm);padding:12px 13px;color:var(--t1);font-size:15px;
  outline:none;transition:border-color var(--dur),box-shadow var(--dur);
  -webkit-appearance:none;appearance:none;
}
.fi:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-l)}
.fi::placeholder{color:var(--t3)}
.fi option{background:var(--bg2);color:var(--t1)}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:11px}

.memo-wrap{overflow:hidden;max-height:0;opacity:0;transition:max-height .25s var(--ease-std),opacity .2s}
.memo-wrap.on{max-height:100px;opacity:1}

.cta{
  width:100%;padding:15px;margin-top:8px;
  background:var(--accent);color:#fff;border:none;border-radius:var(--r-md);
  font-size:15px;font-weight:800;letter-spacing:.1px;cursor:pointer;
  transition:filter var(--dur),transform var(--dur) var(--ease-out);
  box-shadow:0 4px 14px var(--accent-l);
}
.cta:hover{filter:brightness(1.07)}
.cta:active{transform:scale(.98)}

/* ══════════════════════
   HISTORY
══════════════════════ */
.fchips{display:flex;gap:6px;margin-bottom:14px;overflow-x:auto;padding-bottom:2px}
.fchips::-webkit-scrollbar{display:none}
.fc{flex-shrink:0;padding:6px 14px;border-radius:20px;border:1.5px solid var(--line2);background:transparent;font-size:12px;font-weight:600;color:var(--t2);cursor:pointer;transition:all var(--dur)}
.fc.on{background:var(--accent-l);border-color:var(--accent-b);color:var(--accent)}

/* ══════════════════════
   ANALYSIS PAGE
══════════════════════ */
.an-period{
  display:flex;align-items:center;gap:6px;margin-bottom:18px;overflow-x:auto;
  padding-bottom:2px;
}
.an-period::-webkit-scrollbar{display:none}
.ap{flex-shrink:0;padding:6px 14px;border-radius:20px;border:1.5px solid var(--line2);background:transparent;font-size:12px;font-weight:600;color:var(--t2);cursor:pointer;transition:all var(--dur)}
.ap.on{background:var(--accent-l);border-color:var(--accent-b);color:var(--accent)}

/* summary row */
.an-totals{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:18px}
.an-tot{background:var(--bg2);border:1px solid var(--line2);border-radius:var(--r-md);padding:14px 12px;text-align:center;box-shadow:var(--shadow-sm)}
.an-tot-lbl{font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--t3);margin-bottom:5px}
.an-tot-val{font-size:16px;font-weight:800;letter-spacing:-.3px}

/* section card */
.an-card{background:var(--bg2);border:1px solid var(--line2);border-radius:var(--r-md);padding:18px 16px;margin-bottom:14px;box-shadow:var(--shadow-sm)}
.an-card-title{font-size:13px;font-weight:700;color:var(--t1);margin-bottom:14px;display:flex;align-items:center;gap:6px}
.an-card-title span{font-size:11px;font-weight:500;color:var(--t3);margin-left:auto}

/* member cards */
.mem-grid{display:flex;flex-direction:column;gap:12px}
.mem-item{border:1px solid var(--line2);border-radius:var(--r-sm);padding:14px;background:var(--bg3);transition:all var(--dur)}
.mem-item:hover{border-color:var(--line3)}
.mem-top{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.mem-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;flex-shrink:0}
.mem-info{flex:1}
.mem-nm{font-size:14px;font-weight:700}
.mem-cnt{font-size:11px;color:var(--t3);margin-top:1px}
.mem-net{font-size:16px;font-weight:800;letter-spacing:-.3px;text-align:right}
.mem-bars{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.mem-bar-item{background:var(--bg2);border-radius:8px;padding:9px 10px}
.mem-bar-lbl{font-size:10px;font-weight:600;color:var(--t3);margin-bottom:3px}
.mem-bar-val{font-size:13px;font-weight:800}
/* progress ring area */
.mem-top-cats{margin-top:10px;padding-top:10px;border-top:1px solid var(--line2)}
.mem-tc-title{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--t3);margin-bottom:7px}
.mem-cat-row{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.mem-cat-row:last-child{margin-bottom:0}
.mcr-lbl{font-size:11px;color:var(--t2);width:48px;text-align:right;flex-shrink:0}
.mcr-track{flex:1;height:6px;background:var(--bg4);border-radius:3px;overflow:hidden}
.mcr-fill{height:100%;border-radius:3px;transition:width .5s var(--ease-std)}
.mcr-val{font-size:11px;font-weight:700;color:var(--t2);width:58px;text-align:right;flex-shrink:0}

/* cat donut-style list */
.cat-list{display:flex;flex-direction:column;gap:9px}
.cat-item{display:flex;align-items:center;gap:10px}
.cat-rank{width:20px;font-size:11px;font-weight:700;color:var(--t3);text-align:center;flex-shrink:0}
.cat-ic{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.cat-info{flex:1}
.cat-nm{font-size:13px;font-weight:600;margin-bottom:4px}
.cat-track{height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.cat-fill{height:100%;border-radius:3px;transition:width .6s var(--ease-std)}
.cat-rt{text-align:right;flex-shrink:0}
.cat-val{font-size:13px;font-weight:800;color:var(--red)}
.cat-pct{font-size:10px;color:var(--t3);margin-top:2px}

/* donut chart */
.donut-wrap{display:flex;align-items:center;gap:16px;margin-bottom:14px}
.donut-svg{flex-shrink:0}
.donut-legend{flex:1;display:flex;flex-direction:column;gap:6px}
.dl-item{display:flex;align-items:center;gap:6px}
.dl-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dl-nm{font-size:11px;color:var(--t2);flex:1}
.dl-pct{font-size:11px;font-weight:700;color:var(--t1)}


/* ── SEARCH BAR ── */
.search-wrap{position:relative;margin-bottom:14px}
.search-input{
  width:100%;background:var(--bg2);border:1.5px solid var(--line3);
  border-radius:var(--r-md);padding:11px 14px 11px 40px;
  color:var(--t1);font-size:14px;outline:none;
  transition:border-color var(--dur),box-shadow var(--dur);
  -webkit-appearance:none;appearance:none;
}
.search-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-l)}
.search-input::placeholder{color:var(--t3)}
.search-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:15px;color:var(--t3);pointer-events:none}
.search-clear{position:absolute;right:11px;top:50%;transform:translateY(-50%);background:var(--bg3);border:none;border-radius:50%;width:20px;height:20px;font-size:12px;color:var(--t2);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all var(--dur)}
.search-clear:hover{background:var(--red-l);color:var(--red)}
.search-count{font-size:11px;color:var(--t3);margin-bottom:10px;text-align:right}

/* ── PAYMENT METHOD ── */
.pay-btns{display:flex;gap:7px;margin-bottom:0}
.pay-btn{
  flex:1;padding:10px 6px;border-radius:10px;border:1.5px solid var(--line3);
  background:transparent;font-size:13px;font-weight:600;color:var(--t2);
  cursor:pointer;transition:all var(--dur);text-align:center;
}
.pay-btn.on{border-color:var(--blue);background:var(--blue-l);color:var(--blue)}
.card-select-wrap{overflow:hidden;max-height:0;opacity:0;transition:max-height .25s var(--ease-std),opacity .2s;margin-top:0}
.card-select-wrap.on{max-height:80px;opacity:1;margin-top:11px}

/* ── FOOD SUB CATEGORY ── */
.food-sub-wrap{overflow:hidden;max-height:0;opacity:0;transition:max-height .25s var(--ease-std),opacity .2s;margin-top:0}
.food-sub-wrap.on{max-height:80px;opacity:1;margin-top:11px}
.sub-btns{display:flex;gap:7px}
.sub-btn{
  flex:1;padding:9px 6px;border-radius:10px;border:1.5px solid var(--line3);
  background:transparent;font-size:12px;font-weight:600;color:var(--t2);
  cursor:pointer;transition:all var(--dur);text-align:center;
}
.sub-btn.on{border-color:var(--amber);background:var(--amber-l);color:var(--amber)}

/* ── PAY/SUB TAGS ── */
.tg-pay{background:var(--blue-l)!important;color:var(--blue)!important}
.tg-food{background:var(--amber-l)!important;color:var(--amber)!important}


/* ── MEMBER DETAIL ── */
.mem-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.mem-stat-box{background:var(--bg2);border:1px solid var(--line2);border-radius:10px;padding:12px;text-align:center}
.mem-stat-lbl{font-size:10px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--t3);margin-bottom:4px}
.mem-stat-val{font-size:16px;font-weight:800;letter-spacing:-.3px}
.mem-pay-row{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.mem-pay-chip{font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;background:var(--bg3);color:var(--t2)}
.mem-food-row{display:flex;gap:6px;margin-bottom:0;flex-wrap:wrap}

/* ── AI REPORT BANNER ── */
.ai-banner{
  background:var(--bg2);border:1px solid var(--line2);
  border-radius:var(--r-md);padding:16px;margin-bottom:14px;
  box-shadow:var(--shadow-sm);
}
.ai-banner-top{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.ai-badge{
  width:30px;height:30px;border-radius:50%;
  background:var(--purple-l);color:var(--purple);
  display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;
}
.ai-title{font-size:13px;font-weight:700;color:var(--t1)}
.ai-sub{font-size:11px;color:var(--t3);margin-top:1px}
.ai-body{font-size:13px;color:var(--t2);line-height:1.7;white-space:pre-wrap}
.ai-body.loading{color:var(--t3);font-style:italic}
.ai-btn{
  margin-top:12px;padding:9px 16px;border-radius:var(--r-sm);border:none;
  background:var(--purple-l);color:var(--purple);
  font-size:13px;font-weight:700;cursor:pointer;transition:all var(--dur);
  display:flex;align-items:center;gap:6px;
}
.ai-btn:hover{background:var(--purple);color:#fff}
.ai-btn:disabled{opacity:.5;cursor:not-allowed}
.ai-month-notice{
  background:var(--purple-l);border:1px solid var(--purple);
  border-radius:var(--r-md);padding:14px 16px;margin-bottom:14px;
  display:none;
}
.ai-month-notice.show{display:block}
.ai-notice-title{font-size:13px;font-weight:700;color:var(--purple);margin-bottom:4px}
.ai-notice-sub{font-size:12px;color:var(--t2)}

/* ── MODAL ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:flex-end;justify-content:center;z-index:100;backdrop-filter:blur(6px);opacity:0;transition:opacity .25s;pointer-events:none}
.overlay.open{opacity:1;pointer-events:all}
.sheet{background:var(--surf-modal);border:1px solid var(--line2);border-radius:var(--r-xl) var(--r-xl) 0 0;padding:10px 22px calc(env(safe-area-inset-bottom,0px) + 30px);width:100%;max-width:430px;transform:translateY(100%);transition:transform .3s var(--ease-out)}
.overlay.open .sheet{transform:translateY(0)}
.sh-handle{width:34px;height:4px;border-radius:2px;background:var(--line3);margin:0 auto 20px}
.sh-title{font-size:18px;font-weight:800;letter-spacing:-.3px;margin-bottom:5px}
.sh-desc{font-size:13px;color:var(--t2);line-height:1.6;margin-bottom:18px}
.sh-btns{display:flex;gap:9px;margin-top:18px}
.sh-cancel{flex:1;padding:13px;background:var(--bg3);border:1px solid var(--line2);border-radius:var(--r-sm);color:var(--t2);font-size:14px;font-weight:600;cursor:pointer}
.sh-ok{flex:2;padding:13px;background:var(--accent);border:none;border-radius:var(--r-sm);color:#fff;font-size:14px;font-weight:800;cursor:pointer;transition:filter var(--dur)}
.sh-ok:hover{filter:brightness(1.08)}

/* ── TOAST ── */
.toast{position:fixed;bottom:calc(env(safe-area-inset-bottom,0px) + 68px);left:50%;transform:translateX(-50%) translateY(14px);background:var(--t1);color:var(--bg2);padding:10px 20px;border-radius:50px;font-size:13px;font-weight:700;opacity:0;pointer-events:none;transition:opacity .22s,transform .22s var(--ease-out);z-index:200;white-space:nowrap;box-shadow:var(--shadow)}
.toast.on{opacity:1;transform:translateX(-50%) translateY(0)}
</style>
</head>
<body>
<div class="shell">

  <!-- TOPBAR -->
  <header class="topbar">
