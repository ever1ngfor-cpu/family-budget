<div class="toast" id="toast"></div>

<script>
/* ═══════════════ DATA ═══════════════ */
const SK = 'fb_txns_v3', NK = 'fb_name_v3', TK = 'fb_theme_v3';
const ECATS = ['식비','카페','교통','쇼핑','의료','교육','문화','통신','공과금','보험','여행','기타'];
const ICATS = ['급여','부수입','용돈','투자','기타'];
const ICO   = {식비:'🍚',카페:'☕',교통:'🚌',쇼핑:'🛍️',의료:'💊',교육:'📚',문화:'🎬',통신:'📱',공과금:'💡',보험:'🛡️',여행:'✈️',기타:'📌',급여:'💰',부수입:'💵',용돈:'🎁',투자:'📈'};
const PAL   = ['#2d8a00','#0a8a4e','#1e6bb8','#b87000','#7c3aed','#c8392b','#0891b2'];
const PAL_L = ['#f0fae8','#e8f8f0','#eef4fc','#fdf5e6','#f3effe','#fdf0ee','#e0f7fa'];
const CAT_COLORS = ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#14b8a6','#f43f5e','#84cc16','#06b6d4','#6366f1'];

let txns=[], myName='', txType='e', histF='all', anPeriod='all', curPg='home', searchQ='', payMethod='card', foodSub='mart';

/* ═══════════════ STORAGE ═══════════════ */
function load(){
  try{txns=JSON.parse(localStorage.getItem(SK)||'[]')}catch{txns=[]}
  myName=localStorage.getItem(NK)||'';
  const th=localStorage.getItem(TK)||'light';
  document.documentElement.setAttribute('data-theme',th);
  updateThemeBtn(th);
}
function save(){try{localStorage.setItem(SK,JSON.stringify(txns))}catch{toast('저장 오류')}}
function saveName(n){localStorage.setItem(NK,n)}
function saveTheme(t){localStorage.setItem(TK,t)}

/* ═══════════════ THEME ═══════════════ */
function toggleTheme(){
  const next=document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark';
  document.documentElement.setAttribute('data-theme',next);
  saveTheme(next); updateThemeBtn(next);
}
function updateThemeBtn(t){
  document.getElementById('theme-btn').textContent=t==='dark'?'☀️ 라이트':'🌙 다크';
}

/* ═══════════════ HELPERS ═══════════════ */
function fmt(n){return'₩'+Math.abs(n).toLocaleString('ko-KR')}
function fmtShort(n){
  const a=Math.abs(n);
  if(a>=100000000)return(a/100000000).toFixed(1)+'억';
  if(a>=10000)return(a/10000).toFixed(0)+'만';
  return a.toLocaleString('ko-KR');
}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
function memberColor(name,idx){
  const list=[...new Set(txns.map(t=>t.who))];
  const i=idx!=null?idx:list.indexOf(name);
  return PAL[Math.max(0,i)%PAL.length];
}
function memberColorL(name,idx){
  const list=[...new Set(txns.map(t=>t.who))];
  const i=idx!=null?idx:list.indexOf(name);
  return PAL_L[Math.max(0,i)%PAL_L.length];
}
function toast(msg){
  const el=document.getElementById('toast');
  el.textContent=msg; el.classList.add('on');
  clearTimeout(el._t); el._t=setTimeout(()=>el.classList.remove('on'),2400);
}

/* ═══════════════ PERIOD FILTER ═══════════════ */
function filterByPeriod(list){
  if(anPeriod==='all') return list;
  const now=new Date();
  const y=now.getFullYear(), m=now.getMonth();
  if(anPeriod==='this-month'){
    const s=`${y}-${String(m+1).padStart(2,'0')}-01`;
    return list.filter(t=>t.date>=s);
  }
  if(anPeriod==='last-month'){
    const lm=new Date(y,m-1,1);
    const s=`${lm.getFullYear()}-${String(lm.getMonth()+1).padStart(2,'0')}-01`;
    const e=`${y}-${String(m+1).padStart(2,'0')}-01`;
    return list.filter(t=>t.date>=s&&t.date<e);
  }
  if(anPeriod==='3month'){
    const d3=new Date(y,m-2,1);
    const s=`${d3.getFullYear()}-${String(d3.getMonth()+1).padStart(2,'0')}-01`;
    return list.filter(t=>t.date>=s);
  }
  return list;
}

/* ═══════════════ NAVIGATION ═══════════════ */
function go(id,btn,label){
  curPg=id;
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));
  document.getElementById('page-'+id).classList.add('active');
  if(btn) btn.classList.add('on'); else {
    const idx=['home','add','hist','an'].indexOf(id);
    if(idx>=0) document.querySelectorAll('.nb')[idx].classList.add('on');
  }
  document.getElementById('tb-title').textContent=label||'';
  render();
}
function setPeriod(p,btn){
  anPeriod=p;
  document.querySelectorAll('.ap').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  renderAn();
}
function setF(f,btn){
  histF=f;
  document.querySelectorAll('.fc').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  renderHist();
}
function setType(t){
  txType=t;
  document.getElementById('t-e').className='ts'+(t==='e'?' ae':'');
  document.getElementById('t-i').className='ts'+(t==='i'?' ai':'');
  const cats=t==='e'?ECATS:ICATS;
  const sel=document.getElementById('f-cat');
  sel.innerHTML=cats.map(c=>`<option value="${c}">${c}</option>`).join('');
  sel.onchange=()=>{toggleMemo();toggleFoodSub();}; toggleMemo(); toggleFoodSub();
  // 결제수단 섹션: 지출일 때만 표시
  document.getElementById('exp-only-wrap').style.display=t==='e'?'':'none';
}
function toggleMemo(){
  const on=document.getElementById('f-cat').value==='기타';
  document.getElementById('memo-wrap').classList.toggle('on',on);
  if(!on) document.getElementById('f-memo').value='';
}
function toggleFoodSub(){
  const on=document.getElementById('f-cat').value==='식비'&&txType==='e';
  document.getElementById('food-sub-wrap').classList.toggle('on',on);
}
function setPayment(p,btn){
  payMethod=p;
  document.querySelectorAll('.pay-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('card-select-wrap').classList.toggle('on',p==='card');
  if(p==='cash') document.getElementById('f-card').value='';
}
function setFoodSub(s,btn){
  foodSub=s;
  document.querySelectorAll('.sub-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
}


/* ═══════════════ SEARCH ═══════════════ */
function onSearch(){
  searchQ=document.getElementById('search-input').value.trim();
  document.getElementById('search-clear').style.display=searchQ?'flex':'none';
  renderHist();
}
function clearSearch(){
  searchQ='';
  document.getElementById('search-input').value='';
  document.getElementById('search-clear').style.display='none';
  renderHist();
}
function applySearch(list){
  if(!searchQ) return list;
  const q=searchQ.toLowerCase();
  return list.filter(t=>
    t.desc.toLowerCase().includes(q)||
    t.who.toLowerCase().includes(q)||
    t.cat.toLowerCase().includes(q)||
    (t.memo&&t.memo.toLowerCase().includes(q))||
    (t.card&&t.card.toLowerCase().includes(q))
  );
}

/* ═══════════════ TX CARD ═══════════════ */
function txHTML(t){
  const col=memberColor(t.who);
  const mine=t.who===myName;
  const isE=t.type==='e';
  return`<div class="txc">
    <div class="tx-ic" style="background:${isE?'var(--red-l)':'var(--green-l)'}">${ICO[t.cat]||'📌'}</div>
    <div class="tx-bd">
      <div class="tx-nm">${esc(t.desc)}</div>
      <div class="tx-tg">
        <span class="tg">${t.cat}</span>
        ${t.foodSub?`<span class="tg tg-food">${{mart:'🛒 장보기',delivery:'🛵 배달','eating-out':'🍽️ 외식'}[t.foodSub]||''}</span>`:''}
        ${t.payment?`<span class="tg tg-pay">${t.payment==='cash'?'💵 현금':'💳 '+(t.card||'카드')}</span>`:''}
        ${t.memo?`<span class="tg">${esc(t.memo)}</span>`:''}
        <span class="tg tg-who" style="background:${col}18;color:${col}">${esc(t.who)}</span>
      </div>
    </div>
    <div class="tx-rt">
      <span class="tx-am ${isE?'e':'i'}">${isE?'−':'+'}${fmt(t.amount)}</span>
      <span class="tx-dt">${t.date}</span>
      ${mine?`<button class="del" onclick="delTx('${t.id}')">×</button>`:''}
    </div>
  </div>`;
}

/* ═══════════════ RENDER HOME ═══════════════ */
function renderHome(){
  const inc=txns.filter(t=>t.type==='i').reduce((s,t)=>s+t.amount,0);
  const exp=txns.filter(t=>t.type==='e').reduce((s,t)=>s+t.amount,0);
  const bal=inc-exp;
  document.getElementById('h-inc').textContent=fmt(inc);
  document.getElementById('h-exp').textContent=fmt(exp);
  const be=document.getElementById('h-bal');
  be.textContent=(bal<0?'−':'')+fmt(bal);
  be.className='hero-val '+(bal>=0?'pos':'neg');
  const d=new Date();
  document.getElementById('h-date').textContent=`${d.getFullYear()}년 ${d.getMonth()+1}월 ${d.getDate()}일 기준`;
  const rec=[...txns].sort((a,b)=>b.ts-a.ts).slice(0,8);
  document.getElementById('home-list').innerHTML=rec.length
    ?rec.map(txHTML).join('')
    :`<div class="empty"><div class="empty-e">📋</div><div class="empty-t">아직 내역이 없어요</div></div>`;
}

