/* ═══════════════ ADD TX ═══════════════ */
function addTx(){
  const desc=document.getElementById('f-desc').value.trim();
  const amt=parseInt(document.getElementById('f-amt').value)||0;
  const cat=document.getElementById('f-cat').value;
  const date=document.getElementById('f-date').value;
  const whoEl=document.getElementById('f-who');
  const who=whoEl.value.trim()||myName||'나';
  const memoEl=document.getElementById('f-memo');
  const memo=(cat==='기타'&&memoEl)?memoEl.value.trim():'';
  if(!desc){toast('내용을 입력해주세요');return}
  if(amt<=0){toast('금액을 입력해주세요');return}
  if(!date){toast('날짜를 선택해주세요');return}
  const payment = txType==='e' ? payMethod : '';
  const card    = (txType==='e'&&payMethod==='card') ? (document.getElementById('f-card').value||'') : '';
  const fSub    = (txType==='e'&&cat==='식비') ? foodSub : '';
  txns.unshift({id:Date.now().toString(36)+Math.random().toString(36).slice(2,5),type:txType,desc,amount:amt,cat,memo,payment,card,foodSub:fSub,date,who,ts:Date.now()});
  save();
  document.getElementById('f-desc').value='';
  document.getElementById('f-amt').value='';
  if(memoEl) memoEl.value='';
  document.getElementById('f-card').value='';
  whoEl._d=false;
  toast('✓ 저장됐어요!');
  render();
}
function delTx(id){
  if(!confirm('삭제할까요?'))return;
  txns=txns.filter(t=>t.id!==id);save();toast('삭제됐어요');render();
}

