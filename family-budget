      <!-- 합계 -->
      <div class="an-totals">
        <div class="an-tot">
          <div class="an-tot-lbl">수입</div>
          <div class="an-tot-val" id="an-inc" style="color:var(--green)">₩0</div>
        </div>
        <div class="an-tot">
          <div class="an-tot-lbl">지출</div>
          <div class="an-tot-val" id="an-exp" style="color:var(--red)">₩0</div>
        </div>
        <div class="an-tot">
          <div class="an-tot-lbl">잔액</div>
          <div class="an-tot-val" id="an-bal">₩0</div>
        </div>
      </div>

      <!-- AI 월말 리포트 -->
      <div class="ai-month-notice" id="ai-notice">
        <div class="ai-notice-title">📅 이번 달이 거의 끝나가요!</div>
